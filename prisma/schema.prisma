generator client {
  provider = "prisma-client-js"
  output   = "../lib/database/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  // Phase 1 types (existing)
  folder
  note
  file
  html
  template
  code

  // Phase 2 types (new)
  external // ExternalPayload - bookmarks with Open Graph preview
  chat // ChatPayload - chat conversations (stub)
  visualization // VisualizationPayload - charts/graphs (stub)
  data // DataPayload - structured data tables (stub)
  hope // HopePayload - goals/aspirations (stub)
  workflow // WorkflowPayload - automation workflows (stub, inert)
}

enum ContentRole {
  primary // Shown in file tree by default
  referenced // Hidden by default (toggle to show) - embedded/linked content
  system // Always hidden - internal system nodes
}

enum FolderViewMode {
  list // Default list view (current behavior)
  gallery // Media-focused grid with thumbnails
  kanban // Drag-drop cards (project management)
  dashboard // Rearrangeable tiles (overview layout)
  canvas // Visual graph (mind map style)
}

enum ContentWorkspaceStatus {
  active
  archived
}

enum ContentWorkspaceItemAssignmentType {
  primary
  shared
  borrowed
}

enum ContentWorkspaceItemScope {
  item
  recursive
}

model ContentNode {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId       String      @db.Uuid
  title         String      @db.VarChar(255)
  slug          String      @db.VarChar(255)
  contentType   ContentType // Required after Phase 1 backfill
  role          ContentRole @default(primary) // Phase 2: visibility control
  parentId      String?     @db.Uuid
  displayOrder  Int         @default(0)
  categoryId    String?     @db.Uuid
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime?   @db.Timestamptz(6)
  deletedBy     String?     @db.Uuid
  customIcon    String?     @db.VarChar(100)
  iconColor     String?     @db.VarChar(20)
  peopleGroupId String?     @db.Uuid
  personId      String?     @db.Uuid
  auditLogs     AuditLog[]  @relation("AuditedContent")

  // Phase 1 payloads
  codePayload CodePayload?
  filePayload FilePayload?
  htmlPayload HtmlPayload?
  notePayload NotePayload?

  // Phase 2 payloads
  folderPayload        FolderPayload?
  externalPayload      ExternalPayload?
  chatPayload          ChatPayload?
  visualizationPayload VisualizationPayload?
  dataPayload          DataPayload?
  hopePayload          HopePayload?
  workflowPayload      WorkflowPayload?

  history              ContentHistory[]
  sourceLinks          ContentLink[]         @relation("SourceContent")
  targetLinks          ContentLink[]         @relation("TargetContent")
  category             Category?             @relation(fields: [categoryId], references: [id])
  owner                User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent               ContentNode?          @relation("Hierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children             ContentNode[]         @relation("Hierarchy")
  peopleGroup          PeopleGroup?          @relation("PeopleGroupContent", fields: [peopleGroupId], references: [id], onDelete: SetNull)
  person               Person?               @relation("PersonContent", fields: [personId], references: [id], onDelete: SetNull)
  peopleFileTreeMounts PeopleFileTreeMount[] @relation("ContentNodePeopleMounts")
  contentPath          ContentPath?
  contentTags          ContentTag[]
  personMentions       PersonMention[]
  trashBinEntry        TrashBin?
  viewGrants           ViewGrant[]
  calendarEvents       CalendarEvent[]
  workspaceItems  ContentWorkspaceItem[]

  @@unique([ownerId, slug])
  @@index([ownerId, deletedAt])
  @@index([parentId, displayOrder])
  @@index([categoryId, displayOrder])
  @@index([peopleGroupId, displayOrder])
  @@index([personId, displayOrder])
  @@index([deletedAt])
  @@index([role]) // Phase 2: for filtering by visibility
}

model NotePayload {
  contentId  String      @id @db.Uuid
  tiptapJson Json
  searchText String      @default("")
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)
  content    ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model FilePayload {
  contentId        String          @id @db.Uuid
  fileName         String          @db.VarChar(255)
  fileExtension    String?         @db.VarChar(10)
  mimeType         String          @db.VarChar(127)
  fileSize         BigInt
  checksum         String          @db.VarChar(64)
  storageProvider  StorageProvider @default(r2)
  storageKey       String          @db.VarChar(512)
  storageUrl       String?
  storageMetadata  Json            @default("{}")
  uploadStatus     UploadStatus    @default(uploading)
  uploadedAt       DateTime?       @db.Timestamptz(6)
  uploadError      String?
  processingStatus String          @default("pending") @db.VarChar(20)
  isProcessed      Boolean         @default(false)
  thumbnailUrl     String?
  width            Int?
  height           Int?
  duration         Int?
  lastAccessedAt   DateTime?       @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @db.Timestamptz(6)
  searchText       String          @default("")
  content          ContentNode     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([uploadStatus])
  @@index([storageProvider, uploadedAt(sort: Desc)])
  @@index([checksum, fileSize])
  @@index([mimeType])
  @@index([processingStatus, isProcessed])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model HtmlPayload {
  contentId        String      @id @db.Uuid
  html             String
  searchText       String      @default("")
  isTemplate       Boolean     @default(false)
  templateSchema   Json?
  templateMetadata Json        @default("{}")
  renderMode       String      @default("static") @db.VarChar(20)
  templateEngine   String?     @db.VarChar(20)
  createdAt        DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @db.Timestamptz(6)
  content          ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([isTemplate])
}

model CodePayload {
  contentId  String      @id @db.Uuid
  code       String
  language   String      @db.VarChar(50)
  searchText String      @default("")
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)
  content    ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([language])
}

model ContentHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId String      @db.Uuid
  version   Int
  snapshot  Json
  changedBy String      @db.Uuid
  changedAt DateTime    @default(now()) @db.Timestamptz(6)
  user      User        @relation(fields: [changedBy], references: [id])
  content   ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId, version(sort: Desc)])
}

model ContentPath {
  contentId    String      @id @db.Uuid
  path         String      @db.VarChar(2048)
  pathSegments String[]
  depth        Int
  lastUpdated  DateTime    @updatedAt @db.Timestamptz(6)
  content      ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([path])
  @@index([depth])
}

model ContentLink {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId       String      @db.Uuid
  targetId       String      @db.Uuid
  linkType       String      @db.VarChar(20)
  targetFragment String?     @db.VarChar(255)
  context        String?
  createdAt      DateTime    @default(now()) @db.Timestamptz(6)
  source         ContentNode @relation("SourceContent", fields: [sourceId], references: [id], onDelete: Cascade)
  target         ContentNode @relation("TargetContent", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@index([targetId])
}

model ContentTag {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId String      @db.Uuid
  tagId     String      @db.Uuid
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  positions Json        @default("[]")
  content   ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contentId, tagId])
  @@index([tagId])
}

model TrashBin {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId         String      @unique @db.Uuid
  originalPath      String?
  deletedBy         String      @db.Uuid
  deletedAt         DateTime    @default(now()) @db.Timestamptz(6)
  scheduledDeletion DateTime    @db.Timestamptz(6)
  deletionReason    String?     @db.VarChar(255)
  contentSnapshot   Json
  content           ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  deletedByUser     User        @relation(fields: [deletedBy], references: [id])

  @@index([deletedBy])
  @@index([scheduledDeletion])
  @@index([deletedAt(sort: Desc)])
}

model StorageProviderConfig {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid
  provider    StorageProvider
  isDefault   Boolean         @default(false)
  displayName String?         @db.VarChar(100)
  config      Json
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(6)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, isDefault])
}

model AIProviderKey {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @db.Uuid
  providerId   String    @db.VarChar(50)
  encryptedKey String
  label        String    @default("") @db.VarChar(100)
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@index([userId, isActive])
}

model User {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username             String                  @unique @db.VarChar(50)
  passwordHash         String?                 @db.Char(60)
  email                String                  @unique @db.VarChar(255)
  role                 UserRole                @default(guest)
  createdAt            DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                @updatedAt @db.Timestamptz(6)
  settings             Json?
  settingsVersion      Int                     @default(1)
  accounts             Account[]
  aiProviderKeys       AIProviderKey[]
  auditTargets         AuditLog[]              @relation("AuditTargets")
  adminActions         AuditLog[]              @relation("AdminActions")
  categories           Category[]
  contentHistory       ContentHistory[]
  contentNodes         ContentNode[]
  sessions             Session[]
  storageConfigs       StorageProviderConfig[]
  tags                 Tag[]
  trashedContent       TrashBin[]
  viewGrants           ViewGrant[]
  peopleGroups         PeopleGroup[]
  peopleDefaultGroups  PeopleGroup[]           @relation("DefaultPeopleGroup")
  people               Person[]
  peopleFileTreeMounts PeopleFileTreeMount[]
  personMentions       PersonMention[]
  reusableCategories   ReusableCategory[]
  savedBlocks          SavedBlock[]
  contentTemplates     ContentTemplate[]
  snippets             Snippet[]
  pageTemplates        PageTemplate[]
  calendarConnections  CalendarConnection[]
  calendarSources      CalendarSource[]
  calendarEvents       CalendarEvent[]
  contentWorkspaces    ContentWorkspace[]

  @@index([email])
}

model ContentWorkspace {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId      String                 @db.Uuid
  name         String                 @db.VarChar(120)
  slug         String                 @db.VarChar(120)
  isMain       Boolean                @default(false)
  isLocked     Boolean                @default(false)
  status       ContentWorkspaceStatus @default(active)
  expiresAt    DateTime?              @db.Timestamptz(6)
  archivedAt   DateTime?              @db.Timestamptz(6)
  layoutMode   String                 @default("single") @db.VarChar(32)
  activePaneId String                 @default("top-left") @db.VarChar(32)
  paneState    Json                   @default("{}")
  settings     Json                   @default("{}")
  createdAt    DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime               @updatedAt @db.Timestamptz(6)

  owner User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items ContentWorkspaceItem[]

  @@unique([ownerId, slug])
  @@index([ownerId, status])
  @@index([ownerId, isMain])
  @@index([expiresAt])
}

model ContentWorkspaceItem {
  id             String                             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String                             @db.Uuid
  contentId      String                             @db.Uuid
  assignmentType ContentWorkspaceItemAssignmentType @default(primary)
  scope          ContentWorkspaceItemScope          @default(item)
  expiresAt      DateTime?                          @db.Timestamptz(6)
  createdAt      DateTime                           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                           @updatedAt @db.Timestamptz(6)

  workspace ContentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content   ContentNode      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, contentId])
  @@index([contentId, assignmentType, expiresAt])
  @@index([workspaceId, assignmentType])
  @@index([expiresAt])
}

model Category {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(100)
  slug         String        @unique @db.VarChar(100)
  description  String?
  ownerId      String        @db.Uuid
  displayOrder Int           @default(0)
  isPublished  Boolean       @default(false)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contentNodes ContentNode[]

  @@index([ownerId, displayOrder])
}

model Tag {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @db.VarChar(50)
  slug        String       @db.VarChar(50)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  userId      String       @db.Uuid
  color       String?      @db.VarChar(7)
  contentTags ContentTag[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId, name])
}

model ViewGrant {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId   String      @db.Uuid
  userId      String      @db.Uuid
  accessLevel String      @db.VarChar(20)
  grantedAt   DateTime    @default(now()) @db.Timestamptz(6)
  expiresAt   DateTime?   @db.Timestamptz(6)
  content     ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([userId])
}

// ============================================================
// Epoch 13: People Foundations
// ============================================================

model PeopleGroup {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId           String                @db.Uuid
  parentGroupId     String?               @db.Uuid
  defaultForOwnerId String?               @unique @db.Uuid
  name              String                @db.VarChar(120)
  slug              String                @db.VarChar(140)
  description       String?
  displayOrder      Int                   @default(0)
  isDefault         Boolean               @default(false)
  metadata          Json                  @default("{}")
  createdAt         DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?             @db.Timestamptz(6)
  owner             User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  defaultForOwner   User?                 @relation("DefaultPeopleGroup", fields: [defaultForOwnerId], references: [id], onDelete: Cascade)
  parentGroup       PeopleGroup?          @relation("PeopleGroupHierarchy", fields: [parentGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childGroups       PeopleGroup[]         @relation("PeopleGroupHierarchy")
  people            Person[]
  contentNodes      ContentNode[]         @relation("PeopleGroupContent")
  fileTreeMounts    PeopleFileTreeMount[]

  @@unique([ownerId, slug])
  @@index([ownerId, parentGroupId, displayOrder])
  @@index([ownerId, isDefault])
  @@index([parentGroupId])
  @@index([deletedAt])
}

model Person {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId        String                @db.Uuid
  primaryGroupId String                @db.Uuid
  displayName    String                @db.VarChar(160)
  slug           String                @db.VarChar(180)
  givenName      String?               @db.VarChar(120)
  familyName     String?               @db.VarChar(120)
  email          String?               @db.VarChar(255)
  phone          String?               @db.VarChar(50)
  avatarUrl      String?
  metadata       Json                  @default("{}")
  displayOrder   Int                   @default(0)
  createdAt      DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?             @db.Timestamptz(6)
  owner          User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  primaryGroup   PeopleGroup           @relation(fields: [primaryGroupId], references: [id], onDelete: Restrict)
  contentNodes   ContentNode[]         @relation("PersonContent")
  fileTreeMounts PeopleFileTreeMount[]
  mentions       PersonMention[]

  @@unique([ownerId, slug])
  @@index([ownerId, primaryGroupId, displayOrder])
  @@index([ownerId, displayName])
  @@index([email])
  @@index([deletedAt])
}

model PeopleFileTreeMount {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String       @db.Uuid
  contentParentId String?      @db.Uuid
  groupId         String?      @db.Uuid
  personId        String?      @db.Uuid
  displayOrder    Int          @default(0)
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @db.Timestamptz(6)
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contentParent   ContentNode? @relation("ContentNodePeopleMounts", fields: [contentParentId], references: [id], onDelete: Cascade)
  group           PeopleGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  person          Person?      @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([ownerId, groupId])
  @@unique([ownerId, personId])
  @@index([ownerId, contentParentId, displayOrder])
  @@index([contentParentId])
}

model PersonMention {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId   String      @db.Uuid
  contentId String      @db.Uuid
  personId  String      @db.Uuid
  positions Json        @default("[]")
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @db.Timestamptz(6)
  owner     User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  content   ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  person    Person      @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([contentId, personId])
  @@index([ownerId, personId])
  @@index([personId])
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @db.Uuid
  provider          String    @db.VarChar(50)
  providerAccountId String    @db.VarChar(255)
  refreshToken      String?
  accessToken       String?
  scope             String?   @db.Text
  expiresAt         DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([provider, providerAccountId], map: "Account_provider_providerAccId_key")
  @@index([userId])
  @@index([provider])
}

model AuditLog {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @db.Uuid
  action          String       @db.VarChar(100)
  targetUserId    String?      @db.Uuid
  targetContentId String?      @db.Uuid
  details         Json         @default("{}")
  ipAddress       String?      @db.VarChar(45)
  userAgent       String?      @db.VarChar(512)
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  targetContent   ContentNode? @relation("AuditedContent", fields: [targetContentId], references: [id])
  targetUser      User?        @relation("AuditTargets", fields: [targetUserId], references: [id])
  user            User         @relation("AdminActions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

enum UserRole {
  owner
  admin
  member
  guest
}

enum UploadStatus {
  uploading
  ready
  failed
}

enum StorageProvider {
  r2
  s3
  vercel
}

// ============================================================
// Phase 2 Payload Models
// ============================================================

model FolderPayload {
  contentId                String         @id @db.Uuid
  viewMode                 FolderViewMode @default(list)
  sortMode                 String?        @db.VarChar(20) // "asc" | "desc" | null (null = manual/tree order)
  viewPrefs                Json           @default("{}") // View-specific settings (grid size, tile layout, etc.)
  includeReferencedContent Boolean        @default(false) // Show referenced content in this folder view
  createdAt                DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime       @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([viewMode])
}

model ExternalPayload {
  contentId String   @id @db.Uuid
  url       String // External URL (HTTPS-only by default)
  subtype   String?  @default("website") @db.VarChar(20) // "website" | "application" (cosmetic)
  preview   Json     @default("{}") // { mode: "none" | "open_graph", cached: {...} }
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([url])
}

model ChatPayload {
  contentId String   @id @db.Uuid
  messages  Json     @default("[]") // Array of { role, content, timestamp }
  metadata  Json     @default("{}") // { model, temperature, etc. }
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model VisualizationPayload {
  contentId String   @id @db.Uuid
  engine    String   @db.VarChar(50) // "chartjs" | "d3" | "plotly" | "mermaid"
  config    Json     @default("{}") // Engine-specific configuration
  data      Json     @default("{}") // Visualization data
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([engine])
}

model DataPayload {
  contentId String   @id @db.Uuid
  mode      String   @db.VarChar(20) // "inline" | "external" | "query"
  source    Json     @default("{}") // Table data or external source config
  schema    Json     @default("{}") // Column definitions
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([mode])
}

model HopePayload {
  contentId   String    @id @db.Uuid
  kind        String    @db.VarChar(50) // "goal" | "aspiration" | "milestone" | "dream"
  status      String    @db.VarChar(20) // "active" | "achieved" | "deferred" | "archived"
  description String? // Optional rich description
  targetDate  DateTime? @db.Timestamptz(6)
  metadata    Json      @default("{}") // Progress tracking, tags, etc.
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([kind])
  @@index([status])
}

model WorkflowPayload {
  contentId  String   @id @db.Uuid
  engine     String   @db.VarChar(50) // "temporal" | "n8n" | "zapier" (stub only)
  definition Json     @default("{}") // Workflow definition
  enabled    Boolean  @default(false) // ALWAYS false (execution blocked in Phase 2)
  metadata   Json     @default("{}") // Triggers, schedule, etc.
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

// ============================================================
// Epoch 11: Reusable Content (Sprint 43-46)
// ============================================================

enum ReusableCategoryScope {
  content_template
  snippet
  page_template
  saved_block
}

model ReusableCategory {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String                @db.VarChar(100)
  slug             String                @db.VarChar(100)
  scope            ReusableCategoryScope
  userId           String?               @db.Uuid
  parentId         String?               @db.Uuid
  displayOrder     Int                   @default(0)
  createdAt        DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @db.Timestamptz(6)
  user             User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           ReusableCategory?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children         ReusableCategory[]    @relation("CategoryHierarchy")
  contentTemplates ContentTemplate[]
  snippets         Snippet[]
  pageTemplates    PageTemplate[]
  savedBlocks      SavedBlock[]

  @@unique([userId, scope, slug])
  @@index([userId, scope, displayOrder])
  @@index([parentId])
}

model SavedBlock {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String           @db.VarChar(255)
  blockType  String           @db.VarChar(100)
  tiptapJson Json
  searchText String           @default("")
  categoryId String           @db.Uuid
  userId     String?          @db.Uuid
  usageCount Int              @default(0)
  lastUsedAt DateTime?        @db.Timestamptz(6)
  createdAt  DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @db.Timestamptz(6)
  category   ReusableCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId])
  @@index([userId, blockType])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model ContentTemplate {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String           @db.VarChar(255)
  tiptapJson Json
  searchText String           @default("")
  categoryId String           @db.Uuid
  userId     String           @db.Uuid
  usageCount Int              @default(0)
  lastUsedAt DateTime?        @db.Timestamptz(6)
  createdAt  DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @db.Timestamptz(6)
  category   ReusableCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId])
  @@index([userId, lastUsedAt(sort: Desc)])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model Snippet {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String?          @db.VarChar(255)
  content       String
  tiptapJson    Json?
  searchText    String           @default("")
  categoryId    String           @db.Uuid
  userId        String           @db.Uuid
  usageCount    Int              @default(0)
  lastUsedAt    DateTime?        @db.Timestamptz(6)
  isAiContext   Boolean          @default(true)
  isVisibleInUI Boolean          @default(true)
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)
  category      ReusableCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId])
  @@index([userId, isAiContext])
  @@index([userId, isVisibleInUI])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model PageTemplate {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String           @db.VarChar(255)
  tiptapJson   Json
  searchText   String           @default("")
  categoryId   String           @db.Uuid
  userId       String?          @db.Uuid
  defaultTitle String?          @db.VarChar(255)
  customIcon   String?          @db.VarChar(100)
  iconColor    String?          @db.VarChar(20)
  usageCount   Int              @default(0)
  createdAt    DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @db.Timestamptz(6)
  category     ReusableCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

// ============================================================
// Epoch 11: Calendar Integration (Sprint 50-52)
// ============================================================

model CalendarConnection {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @db.Uuid
  provider       String           @db.VarChar(20)
  displayName    String           @db.VarChar(255)
  status         String           @default("active") @db.VarChar(30)
  syncStatus     String           @default("idle") @db.VarChar(20)
  providerConfig Json             @default("{}")
  syncCursor     String?
  lastSyncedAt   DateTime?        @db.Timestamptz(6)
  lastSyncError  String?
  createdAt      DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(6)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources        CalendarSource[]

  @@index([userId, provider])
}

model CalendarSource {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String              @db.Uuid
  connectionId       String?             @db.Uuid
  title              String              @db.VarChar(255)
  color              String              @default("#2563EB") @db.VarChar(7)
  timezone           String?             @db.VarChar(100)
  visible            Boolean             @default(true)
  isReadOnly         Boolean             @default(false)
  isPrimary          Boolean             @default(false)
  syncMode           String              @default("local") @db.VarChar(20)
  externalCalendarId String?             @db.VarChar(255)
  metadata           Json                @default("{}")
  lastSyncedAt       DateTime?           @db.Timestamptz(6)
  lastSyncError      String?
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(6)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection         CalendarConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  events             CalendarEvent[]

  @@unique([userId, externalCalendarId])
  @@index([userId, connectionId])
  @@index([userId, syncMode])
  @@index([userId, isPrimary])
}

model CalendarEvent {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String                  @db.Uuid
  sourceId            String                  @db.Uuid
  externalEventId     String?                 @db.VarChar(512)
  title               String                  @db.VarChar(255)
  description         String?
  location            String?                 @db.VarChar(512)
  startAt             DateTime                @db.Timestamptz(6)
  endAt               DateTime                @db.Timestamptz(6)
  allDay              Boolean                 @default(false)
  timezone            String?                 @db.VarChar(100)
  recurrenceRule      String?
  recurrenceExDates   Json                    @default("[]")
  recurrenceOverrides Json                    @default("{}")
  status              String                  @default("confirmed") @db.VarChar(20)
  meetingUrl          String?                 @db.VarChar(512)
  linkedContentId     String?                 @db.Uuid
  providerMetadata    Json                    @default("{}")
  lastSyncedAt        DateTime?               @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                @updatedAt @db.Timestamptz(6)
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              CalendarSource          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  linkedContent       ContentNode?            @relation(fields: [linkedContentId], references: [id], onDelete: SetNull)
  attendees           CalendarEventAttendee[]

  @@unique([sourceId, externalEventId])
  @@index([userId, startAt, endAt])
  @@index([sourceId, startAt])
  @@index([linkedContentId])
}

model CalendarEventAttendee {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId        String        @db.Uuid
  email          String        @db.VarChar(255)
  displayName    String?       @db.VarChar(255)
  isOrganizer    Boolean       @default(false)
  responseStatus String        @default("needs_action") @db.VarChar(20)
  event          CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([email])
}
