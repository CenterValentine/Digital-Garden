  source    Json     @default("{}") // Table data or external source config
  schema    Json     @default("{}") // Column definitions
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  content ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([mode])
}

model HopePayload {
  contentId   String    @id @db.Uuid
  kind        String    @db.VarChar(50) // "goal" | "aspiration" | "milestone" | "dream"
  status      String    @db.VarChar(20) // "active" | "achieved" | "deferred" | "archived"
  description String? // Optional rich description
  targetDate  DateTime? @db.Timestamptz(6)
  metadata    Json      @default("{}") // Progress tracking, tags, etc.
