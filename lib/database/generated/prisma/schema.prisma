// Publishing System
// ============================================================

enum PublicItemType {
  blog_post
  project
  profile_section
  case_study
  bookmark
  page
  media_item
}

enum PublishState {
  draft
  published
  scheduled
  unpublished
  archived
}

enum ValidationStatus {
  unchecked
  ok
  warnings
  blocked
}

enum CoverPosition {
  top
  center
  bottom
  left
  right
}

enum RelatedStrategy {
  same_path
  same_tags
  same_type
  manual
  none
}

enum ProjectStatus {
  active
  completed
  archived
  wip
}

enum ProfileLayout {
  single_column
  two_column
  split_hero
  timeline
}

enum MediaDisplayVariant {
  gallery
  slideshow
  single
  mosaic
}

// Multi-tenancy foundation (Epoch 18). A Tenant is a publishing destination
// — typically a website — that one or more hosts route to. A user owns one
// or more tenants; each PublicItem and PublicPath belongs to exactly one.
// In UI we call this "Site". See docs/notes-feature/work-tracking/epochs/epoch-18-multi-tenancy.md.
model Tenant {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId      String   @db.Uuid
  slug         String   @unique @db.VarChar(120)
  displayName  String   @db.VarChar(255)
  isPersonal   Boolean  @default(false)
  // Forward-looking placeholder for a future tenant-authored home template.
  // Not read by any code in Epoch 18 — reserved so a future template engine
  // can land without a schema migration.
  homeTemplate String?  @db.VarChar(120)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  owner               User                 @relation("OwnedTenants", fields: [ownerId], references: [id], onDelete: Cascade)
  hosts               TenantHost[]
  publicPaths         PublicPath[]
  publicItems         PublicItem[]
  publicPathRedirects PublicPathRedirect[]
  primaryForUsers     User[]               @relation("PrimaryTenantOfUser")

  @@index([ownerId])
}

model TenantHost {
  host             String    @id @db.VarChar(253)
  tenantId         String    @db.Uuid
  isPrimary        Boolean   @default(false)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  verifiedAt       DateTime? @db.Timestamptz(6)
  vercelConfigData Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PublicPath {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId      String   @db.Uuid
  parentId     String?  @db.Uuid
  tenantId     String?  @db.Uuid
  slug         String   @db.VarChar(120)
  title        String   @db.VarChar(255)
  description  String?
  displayOrder Int      @default(0)
  icon         String?  @db.VarChar(100)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  parent      PublicPath?          @relation("PublicPathHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    PublicPath[]         @relation("PublicPathHierarchy")
  items       PublicItem[]
  redirectsTo PublicPathRedirect[] @relation("TargetPath")

  @@unique([parentId, slug])
  @@index([ownerId, parentId, displayOrder])
  @@index([ownerId])
  @@index([tenantId, parentId])
}

model Series {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId      String   @db.Uuid
  title        String   @db.VarChar(255)
  slug         String   @db.VarChar(120)
  description  String?
  heroImageUrl String?  @db.VarChar(2048)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  owner User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items PublicItem[]

  @@unique([ownerId, slug])
  @@index([ownerId, displayOrder])
}

model PublicItem {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId             String           @db.Uuid
  tenantId            String?          @db.Uuid
  contentNodeId       String           @db.Uuid
  pathId              String           @db.Uuid
  slug                String           @db.VarChar(120)
  payloadType         PublicItemType
  publicTitle         String?          @db.VarChar(255)
  publicTags          String[]
  state               PublishState     @default(draft)
  scheduledFor        DateTime?        @db.Timestamptz(6)
  workingRevisionId   String?          @unique @db.Uuid
  publishedRevisionId String?          @unique @db.Uuid
  seriesId            String?          @db.Uuid
  seriesOrder         Int?
  deletedAt           DateTime?        @db.Timestamptz(6)
  firstPublishedAt    DateTime?        @db.Timestamptz(6)
  lastPublishedAt     DateTime?        @db.Timestamptz(6)
  validationStatus    ValidationStatus @default(unchecked)
  validationCheckedAt DateTime?        @db.Timestamptz(6)
  validationIssues    Json             @default("[]")
  createdAt           DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @db.Timestamptz(6)

  owner             User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tenant            Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contentNode       ContentNode          @relation(fields: [contentNodeId], references: [id], onDelete: Cascade)
  path              PublicPath           @relation(fields: [pathId], references: [id], onDelete: Restrict)
  series            Series?              @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  workingRevision   PublicItemRevision?  @relation("WorkingRevision", fields: [workingRevisionId], references: [id], onDelete: SetNull)
  publishedRevision PublicItemRevision?  @relation("PublishedRevision", fields: [publishedRevisionId], references: [id], onDelete: SetNull)
  revisions         PublicItemRevision[] @relation("AllRevisions")
  previewTokens     PreviewToken[]
  redirects         PublicPathRedirect[]

  blogPostPayload       BlogPostPayload?
  projectPayload        ProjectPayload?
  profileSectionPayload ProfileSectionPayload?
  caseStudyPayload      CaseStudyPayload?
  bookmarkPayload       BookmarkPayload?
  pagePayload           PagePayload?
  mediaItemPayload      MediaItemPayload?

  @@unique([pathId, slug])
  @@index([ownerId, state])
  @@index([ownerId, payloadType])
  @@index([contentNodeId])
  @@index([seriesId, seriesOrder])
  @@index([scheduledFor])
  @@index([deletedAt])
  @@index([ownerId, lastPublishedAt(sort: Desc)])
  @@index([tenantId, state])
  @@index([tenantId, state, deletedAt])
  @@index([tenantId, lastPublishedAt(sort: Desc)])
}

model PublicItemRevision {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicItemId       String    @db.Uuid
  bodyJson           Json
  metadataSnapshot   Json      @default("{}")
  ogTitle            String?   @db.VarChar(255)
  ogDescription      String?
  ogImageUrl         String?   @db.VarChar(2048)
  readingTimeMinutes Int?
  wordCount          Int?
  note               String?   @db.VarChar(500)
  bodyHash           String    @db.VarChar(64)
  metadataHash       String    @db.VarChar(64)
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  publishedAt        DateTime? @db.Timestamptz(6)
  authorId           String    @db.Uuid

  publicItem   PublicItem  @relation("AllRevisions", fields: [publicItemId], references: [id], onDelete: Cascade)
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workingFor   PublicItem? @relation("WorkingRevision")
  publishedFor PublicItem? @relation("PublishedRevision")

  @@index([publicItemId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([publishedAt])
}

model PublicPathRedirect {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId  String  @db.Uuid
  tenantId String? @db.Uuid

  fromPath       String    @unique @db.VarChar(2048)
  toPathId       String?   @db.Uuid
  toPublicItemId String?   @db.Uuid
