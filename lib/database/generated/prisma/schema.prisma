generator client {
  provider = "prisma-client-js"
  output   = "../lib/database/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  // Phase 1 types (existing)
  folder
  note
  file
  html
  template
  code

  // Phase 2 types (new)
  external // ExternalPayload - bookmarks with Open Graph preview
  chat // ChatPayload - chat conversations (stub)
  visualization // VisualizationPayload - charts/graphs (stub)
  data // DataPayload - structured data tables (stub)
  hope // HopePayload - goals/aspirations (stub)
  workflow // WorkflowPayload - automation workflows (stub, inert)
}

enum ContentRole {
  primary // Shown in file tree by default
  referenced // Hidden by default (toggle to show) - embedded/linked content
  system // Always hidden - internal system nodes
}

enum FolderViewMode {
  list // Default list view (current behavior)
  gallery // Media-focused grid with thumbnails
  kanban // Drag-drop cards (project management)
  dashboard // Rearrangeable tiles (overview layout)
  canvas // Visual graph (mind map style)
}

enum ContentWorkspaceStatus {
  active
  archived
}

enum ContentWorkspaceItemAssignmentType {
  primary
  shared
  borrowed
}

enum ContentWorkspaceItemScope {
  item
  recursive
}

enum FlashcardReviewOutcome {
  review
  mastered
}

enum FlashcardReviewMode {
  front_to_back
  back_to_front
  random
  reference
}

enum FlashcardShownSide {
  front
  back
}

// FSRS scheduling state (Epoch 19). Mirrors ts-fsrs's State enum:
//   new(0) | learning(1) | review(2) | relearning(3).
// suspended/archived are user-driven holds the algorithm ignores.
enum FlashcardState {
  new
  learning
  review
  relearning
  suspended
  archived
}

// 4-button rating used by FSRS. Mirrors ts-fsrs's Rating enum:
//   again(1) | hard(2) | good(3) | easy(4).
enum FlashcardRating {
  again
  hard
  good
  easy
}

// Card variant. `basic` is the historical default. `cloze` is wired in
// Session 2B alongside noteId + clozeOrdinal + clozeSourceJson on the
// Flashcard model; sibling cloze cards generated from the same source
// document share a noteId.
enum FlashcardCardType {
  basic
  cloze
}

enum ExternalReadingStatus {
  inbox
  queue
  reading
  read
  archived
}

model ContentNode {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId       String      @db.Uuid
  title         String      @db.VarChar(255)
  slug          String      @db.VarChar(255)
  contentType   ContentType // Required after Phase 1 backfill
  role          ContentRole @default(primary) // Phase 2: visibility control
  parentId      String?     @db.Uuid
  displayOrder  Int         @default(0)
  categoryId    String?     @db.Uuid
  isPublished   Boolean     @default(false)
  bodyHash      String?     @db.VarChar(64)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime?   @db.Timestamptz(6)
  deletedBy     String?     @db.Uuid
  lastViewedAt  DateTime?   @db.Timestamptz(6)
  customIcon    String?     @db.VarChar(100)
  iconColor     String?     @db.VarChar(20)
  peopleGroupId String?     @db.Uuid
  personId      String?     @db.Uuid
  ownedByNoteId String?     @db.Uuid
  auditLogs     AuditLog[]  @relation("AuditedContent")

  // Phase 1 payloads
  codePayload CodePayload?
  filePayload FilePayload?
  htmlPayload HtmlPayload?
  notePayload NotePayload?

  // Phase 2 payloads
  folderPayload        FolderPayload?
  externalPayload      ExternalPayload?
  chatPayload          ChatPayload?
  visualizationPayload VisualizationPayload?
  dataPayload          DataPayload?
  hopePayload          HopePayload?
  workflowPayload      WorkflowPayload?

  history                      ContentHistory[]
  sourceLinks                  ContentLink[]             @relation("SourceContent")
  targetLinks                  ContentLink[]             @relation("TargetContent")
  category                     Category?                 @relation(fields: [categoryId], references: [id])
  owner                        User                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent                       ContentNode?              @relation("Hierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children                     ContentNode[]             @relation("Hierarchy")
  ownedByNote                  ContentNode?              @relation("ContentOwnedByNote", fields: [ownedByNoteId], references: [id], onDelete: SetNull)
  ownedEmbeds                  ContentNode[]             @relation("ContentOwnedByNote")
  peopleGroup                  PeopleGroup?              @relation("PeopleGroupContent", fields: [peopleGroupId], references: [id], onDelete: SetNull)
  archivedConversation         Conversation?             @relation("ConversationArchive")
  conversationAssociations     ConversationAssociation[] @relation("ConversationAssoc")
  person                       Person?                   @relation("PersonContent", fields: [personId], references: [id], onDelete: SetNull)
  peopleFileTreeMounts         PeopleFileTreeMount[]     @relation("ContentNodePeopleMounts")
  collaborationDocument        CollaborationDocument?
  collaborationPresenceRecords CollaborationPresence[]
  contentPath                  ContentPath?
  contentTags                  ContentTag[]
  personMentions               PersonMention[]
  trashBinEntry                TrashBin?
  viewGrants                   ViewGrant[]
  calendarEvents               CalendarEvent[]
  workspaceItems               ContentWorkspaceItem[]
  viewWorkspaces               ContentWorkspace[]        @relation("WorkspaceViewRoot")
  periodicNoteIndexes          PeriodicNoteIndex[]
  sourceFlashcards             Flashcard[]               @relation("FlashcardSourceContent")
  publicItems                  PublicItem[]
  bookmarkSyncLinks            BookmarkSyncLink[]
  bookmarkSyncRoots            BookmarkSyncConnection[]  @relation("BookmarkSyncRoot")
  webResourceLinks             WebResourceContentLink[]
  webResourceViewStates        WebResourceViewState[]

  @@unique([ownerId, slug])
  @@index([ownerId, deletedAt])
  @@index([parentId, displayOrder])
  @@index([categoryId, displayOrder])
  @@index([peopleGroupId, displayOrder])
  @@index([personId, displayOrder])
  @@index([deletedAt])
  @@index([role]) // Phase 2: for filtering by visibility
  @@index([ownedByNoteId])
  @@index([ownerId, lastViewedAt])
}

model PeriodicNoteIndex {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId   String      @db.Uuid
  kind      String      @db.VarChar(20)
  periodKey String      @db.VarChar(32)
  contentId String      @db.Uuid
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @db.Timestamptz(6)
  owner     User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  content   ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([ownerId, kind, periodKey])
  @@index([contentId])
}

// Nested deck for grouping flashcards (Epoch 19, Migration A). Belongs to
// a single owner. parentDeckId + materialized `path` gives Anki-style
// hierarchical decks ("spanish/verbs/irregular") with cheap descendant
// queries via path LIKE 'spanish/%'.
model FlashcardDeck {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId      String    @db.Uuid
  parentDeckId String?   @db.Uuid
  name         String    @db.VarChar(120)
  slug         String    @db.VarChar(140)
  path         String    @db.VarChar(500)
  description  String?   @db.VarChar(500)
  displayOrder Int       @default(0)
  iconName     String?   @db.VarChar(60)
  iconColor    String?   @db.VarChar(20)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent     FlashcardDeck?  @relation("FlashcardDeckHierarchy", fields: [parentDeckId], references: [id], onDelete: SetNull)
  children   FlashcardDeck[] @relation("FlashcardDeckHierarchy")
  flashcards Flashcard[]

  @@unique([ownerId, slug])
  @@unique([ownerId, parentDeckId, name])
  @@index([ownerId, deletedAt])
  @@index([ownerId, path])
  @@index([parentDeckId, displayOrder])
}

model Flashcard {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String    @db.Uuid
  sourceContentId String?   @db.Uuid
  frontLabel      String    @default("Question") @db.VarChar(80)
  backLabel       String    @default("Answer") @db.VarChar(80)
  frontContent    Json
  backContent     Json
  isFrontRichText Boolean   @default(false)
  viewCount       Int       @default(0)
  lastReviewedAt  DateTime? @db.Timestamptz(6)
  lastViewedAt    DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  // ---- FSRS additions (Epoch 19, Migration A; deckId promoted to
  // ---- NOT NULL in Migration C, Sprint 6 — legacy columns sunset).
  deckId        String            @db.Uuid
  cardType      FlashcardCardType @default(basic)
  state         FlashcardState    @default(new)
  due           DateTime          @default(now()) @db.Timestamptz(6)
  stability     Float             @default(0)
  difficulty    Float             @default(0)
  elapsedDays   Float             @default(0)
  scheduledDays Float             @default(0)
  reps          Int               @default(0)
  lapses        Int               @default(0)
  learningSteps Int               @default(0)
  suspendedAt   DateTime?         @db.Timestamptz(6)
  archivedAt    DateTime?         @db.Timestamptz(6)
  deletedAt     DateTime?         @db.Timestamptz(6)

  // ---- Cloze additions (Anki import / Session 2B). noteId is a loose
  // ---- pointer (no FK) — promote to a real FK later if shared state grows.
  noteId          String? @db.Uuid
  clozeOrdinal    Int?
  // Source TipTap document the cloze cards were generated from. Stored
  // on each sibling for simple re-extraction on edit; if storage cost
  // becomes a concern this can move to a sidecar table keyed by noteId.
  clozeSourceJson Json?

  owner          User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deck           FlashcardDeck            @relation(fields: [deckId], references: [id], onDelete: Restrict)
  sourceContent  ContentNode?             @relation("FlashcardSourceContent", fields: [sourceContentId], references: [id], onDelete: SetNull)
  reviewAttempts FlashcardReviewAttempt[]

  @@index([sourceContentId])
  @@index([ownerId, deckId])
  @@index([ownerId, due])
  @@index([ownerId, state, due])
  @@index([ownerId, deletedAt])
  @@index([ownerId, noteId])
}

model FlashcardReviewAttempt {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flashcardId        String                 @db.Uuid
  ownerId            String                 @db.Uuid
  outcome            FlashcardReviewOutcome
  reviewMode         FlashcardReviewMode
  shownSide          FlashcardShownSide
  responseTimeMs     Int?
  // ---- FSRS additions (Epoch 19, Migration A). rating is nullable so
  // ---- back-compat rows (no 4-button data) coexist, and reference-mode
  // ---- skims log a row without polluting the scheduler.
  rating             FlashcardRating?
  stateBefore        FlashcardState?
  stateAfter         FlashcardState?
  previousDue        DateTime?              @db.Timestamptz(6)
  scheduledDue       DateTime?              @db.Timestamptz(6)
  previousStability  Float?
  newStability       Float?
  previousDifficulty Float?
  newDifficulty      Float?
  createdAt          DateTime               @default(now()) @db.Timestamptz(6)
  flashcard          Flashcard              @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  owner              User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([flashcardId, createdAt])
  @@index([ownerId, createdAt])
  @@index([ownerId, rating, createdAt])
}

model NotePayload {
  contentId  String      @id @db.Uuid
  tiptapJson Json
  searchText String      @default("")
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)
  content    ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model FilePayload {
  contentId        String          @id @db.Uuid
  fileName         String          @db.VarChar(255)
  fileExtension    String?         @db.VarChar(10)
  mimeType         String          @db.VarChar(127)
  fileSize         BigInt
  checksum         String          @db.VarChar(64)
  storageProvider  StorageProvider @default(r2)
  storageKey       String          @db.VarChar(512)
  storageUrl       String?
  storageMetadata  Json            @default("{}")
  uploadStatus     UploadStatus    @default(uploading)
  uploadedAt       DateTime?       @db.Timestamptz(6)
  uploadError      String?
  processingStatus String          @default("pending") @db.VarChar(20)
  isProcessed      Boolean         @default(false)
  thumbnailUrl     String?
  width            Int?
  height           Int?
  blurDataUrl      String?         @db.VarChar(2048)
  duration         Int?
  lastAccessedAt   DateTime?       @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @db.Timestamptz(6)
  searchText       String          @default("")
  content          ContentNode     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([uploadStatus])
  @@index([storageProvider, uploadedAt(sort: Desc)])
  @@index([checksum, fileSize])
  @@index([mimeType])
  @@index([processingStatus, isProcessed])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model HtmlPayload {
  contentId        String      @id @db.Uuid
  html             String
  searchText       String      @default("")
  isTemplate       Boolean     @default(false)
  templateSchema   Json?
  templateMetadata Json        @default("{}")
  renderMode       String      @default("static") @db.VarChar(20)
  templateEngine   String?     @db.VarChar(20)
  createdAt        DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @db.Timestamptz(6)
  content          ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([isTemplate])
}

model CodePayload {
  contentId  String      @id @db.Uuid
  code       String
  language   String      @db.VarChar(50)
  searchText String      @default("")
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)
  content    ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([language])
}

model ContentHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId String      @db.Uuid
  version   Int
  snapshot  Json
  changedBy String      @db.Uuid
  changedAt DateTime    @default(now()) @db.Timestamptz(6)
  user      User        @relation(fields: [changedBy], references: [id])
  content   ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId, version(sort: Desc)])
}

model ContentPath {
  contentId    String      @id @db.Uuid
  path         String      @db.VarChar(2048)
  pathSegments String[]
  depth        Int
  lastUpdated  DateTime    @updatedAt @db.Timestamptz(6)
  content      ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([path])
  @@index([depth])
}

model ContentLink {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId       String      @db.Uuid
  targetId       String      @db.Uuid
  linkType       String      @db.VarChar(20)
  targetFragment String?     @db.VarChar(255)
  context        String?
  createdAt      DateTime    @default(now()) @db.Timestamptz(6)
  source         ContentNode @relation("SourceContent", fields: [sourceId], references: [id], onDelete: Cascade)
  target         ContentNode @relation("TargetContent", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@index([targetId])
}

model ContentTag {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId String      @db.Uuid
  tagId     String      @db.Uuid
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  positions Json        @default("[]")
  content   ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contentId, tagId])
  @@index([tagId])
}

model TrashBin {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId         String      @unique @db.Uuid
  originalPath      String?
  deletedBy         String      @db.Uuid
  deletedAt         DateTime    @default(now()) @db.Timestamptz(6)
  scheduledDeletion DateTime    @db.Timestamptz(6)
  deletionReason    String?     @db.VarChar(255)
  contentSnapshot   Json
  content           ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  deletedByUser     User        @relation(fields: [deletedBy], references: [id])

  @@index([deletedBy])
  @@index([scheduledDeletion])
  @@index([deletedAt(sort: Desc)])
}

model StorageProviderConfig {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid
  provider    StorageProvider
  isDefault   Boolean         @default(false)
  displayName String?         @db.VarChar(100)
  config      Json
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(6)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, isDefault])
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username                String                   @unique @db.VarChar(50)
  passwordHash            String?                  @db.Char(60)
  email                   String                   @unique @db.VarChar(255)
  role                    UserRole                 @default(guest)
  createdAt               DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @db.Timestamptz(6)
  settings                Json?
  settingsVersion         Int                      @default(1)
  // ---- FSRS user-level settings (Epoch 19, Migration A) ----
  fsrsParameters          Json                     @default("{}")
  desiredRetention        Float                    @default(0.9)
  fsrsMaxInterval         Int                      @default(36500)
  defaultFlashcardDeckId  String?                  @db.Uuid
  accounts                Account[]
  aiConnections           AIConnection[]
  aiFeatureRoutes         AIFeatureRoute[]
  auditTargets            AuditLog[]               @relation("AuditTargets")
  adminActions            AuditLog[]               @relation("AdminActions")
  categories              Category[]
  contentHistory          ContentHistory[]
  contentNodes            ContentNode[]
  conversations           Conversation[]
  sessions                Session[]
  storageConfigs          StorageProviderConfig[]
  tags                    Tag[]
  trashedContent          TrashBin[]
  viewGrants              ViewGrant[]
  peopleGroups            PeopleGroup[]
  peopleDefaultGroups     PeopleGroup[]            @relation("DefaultPeopleGroup")
  people                  Person[]
  peopleFileTreeMounts    PeopleFileTreeMount[]
  personMentions          PersonMention[]
  reusableCategories      ReusableCategory[]
  savedBlocks             SavedBlock[]
  contentTemplates        ContentTemplate[]
  snippets                Snippet[]
  pageTemplates           PageTemplate[]
  calendarConnections     CalendarConnection[]
  calendarSources         CalendarSource[]
  calendarEvents          CalendarEvent[]
  contentWorkspaces       ContentWorkspace[]
  collaborationDocuments  CollaborationDocument[]
  periodicNoteIndexes     PeriodicNoteIndex[]
  flashcards              Flashcard[]
  flashcardReviewAttempts FlashcardReviewAttempt[]
  flashcardDecks          FlashcardDeck[]
  publicPaths             PublicPath[]
  publicItems             PublicItem[]
  publicItemRevisions     PublicItemRevision[]
  previewTokens           PreviewToken[]
  publicPathRedirects     PublicPathRedirect[]
  primaryTenantId         String?                  @db.Uuid
  primaryTenant           Tenant?                  @relation("PrimaryTenantOfUser", fields: [primaryTenantId], references: [id], onDelete: SetNull)
  ownedTenants            Tenant[]                 @relation("OwnedTenants")

  series                   Series[]
  browserExtensionTokens   BrowserExtensionToken[]
  browserExtensionInstalls BrowserExtensionInstall[]
  bookmarkSyncConnections  BookmarkSyncConnection[]
  webResources             WebResource[]
  webResourceContentLinks  WebResourceContentLink[]
  webResourceViewStates    WebResourceViewState[]

  @@index([email])
}

model ContentWorkspace {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId           String                 @db.Uuid
  name              String                 @db.VarChar(120)
  slug              String                 @db.VarChar(120)
  isMain            Boolean                @default(false)
  isLocked          Boolean                @default(false)
  status            ContentWorkspaceStatus @default(active)
  expiresAt         DateTime?              @db.Timestamptz(6)
  archivedAt        DateTime?              @db.Timestamptz(6)
  layoutMode        String                 @default("single") @db.VarChar(32)
  activePaneId      String                 @default("top-left") @db.VarChar(32)
  paneState         Json                   @default("{}")
  settings          Json                   @default("{}")
  viewRootContentId String?                @db.Uuid
  createdAt         DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @db.Timestamptz(6)

  owner    User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  viewRoot ContentNode?           @relation("WorkspaceViewRoot", fields: [viewRootContentId], references: [id], onDelete: SetNull)
  items    ContentWorkspaceItem[]

  @@unique([ownerId, slug])
  @@index([ownerId, status])
  @@index([ownerId, isMain])
  @@index([expiresAt])
}

model ContentWorkspaceItem {
  id             String                             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String                             @db.Uuid
  contentId      String                             @db.Uuid
  assignmentType ContentWorkspaceItemAssignmentType @default(primary)
  scope          ContentWorkspaceItemScope          @default(item)
  expiresAt      DateTime?                          @db.Timestamptz(6)
  createdAt      DateTime                           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                           @updatedAt @db.Timestamptz(6)

  workspace ContentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content   ContentNode      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, contentId])
  @@index([contentId, assignmentType, expiresAt])
  @@index([workspaceId, assignmentType])
  @@index([expiresAt])
}

model Category {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(100)
  slug         String        @unique @db.VarChar(100)
  description  String?
  ownerId      String        @db.Uuid
  displayOrder Int           @default(0)
  isPublished  Boolean       @default(false)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contentNodes ContentNode[]

  @@index([ownerId, displayOrder])
}

model Tag {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @db.VarChar(50)
  slug        String       @db.VarChar(50)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  userId      String       @db.Uuid
  color       String?      @db.VarChar(7)
  contentTags ContentTag[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId, name])
}

model ViewGrant {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId   String      @db.Uuid
  userId      String      @db.Uuid
  accessLevel String      @db.VarChar(20)
  grantedAt   DateTime    @default(now()) @db.Timestamptz(6)
  expiresAt   DateTime?   @db.Timestamptz(6)
  content     ContentNode @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([userId])
}

model CollaborationDocument {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentId     String      @unique @db.Uuid
  ownerId       String      @db.Uuid
  documentName  String      @unique @db.VarChar(160)
  ydocState     Bytes?
  snapshotJson  Json?
  schemaVersion Int         @default(1)
  enabledAt     DateTime    @default(now()) @db.Timestamptz(6)
