  ogImageUrl    String? @db.VarChar(2048)
  siteName      String? @db.VarChar(255)

  publicItem PublicItem @relation(fields: [publicItemId], references: [id], onDelete: Cascade)
}

model PagePayload {
  publicItemId  String        @id @db.Uuid
  coverImageUrl String?       @db.VarChar(2048)
  coverPosition CoverPosition @default(center)
  isRoot        Boolean       @default(false)
  metadata      Json          @default("{}")

  publicItem PublicItem @relation(fields: [publicItemId], references: [id], onDelete: Cascade)
}

model MediaItemPayload {
  publicItemId    String              @id @db.Uuid
  displayVariant  MediaDisplayVariant @default(single)
  caption         String?
  altText         String?             @db.VarChar(500)
  credit          String?             @db.VarChar(255)
  mediaContentIds String[]            @db.Uuid

  publicItem PublicItem @relation(fields: [publicItemId], references: [id], onDelete: Cascade)
}
