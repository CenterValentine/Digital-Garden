# Local Postgres dev env — DB-related vars only.
#
# This file is COMMITTED to source control as a template.
# Your real `.env.local` is gitignored. Never commit secrets.
#
# Workflow (see docs/notes-feature/guides/database/LOCAL-POSTGRES.md):
#
#   1. Back up your existing .env.local:
#        cp .env.local .env.local.neon
#
#   2. Merge these two lines into .env.local (replacing the existing DATABASE_URL).
#      Keep your OAuth, AI, and storage credentials unchanged — they don't depend
#      on which database you're pointed at.
#
#   3. Confirm the swap:
#        pnpm db:target
#      Expect the "LOCAL POSTGRES" banner.
#
#   4. Apply migrations + seed:
#        npx prisma migrate deploy
#        pnpm db:seed
#
# To switch back to Neon: restore .env.local from .env.local.neon.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digital_garden_dev?schema=public"

# Marker read by scripts/check-db-target.ts. Required when DATABASE_URL is local.
LOCAL_POSTGRES=1

# Optional: override the host port if 5432 is taken (e.g. system Postgres).
# Must match the port in docker-compose.yml AND the DATABASE_URL above.
# LOCAL_POSTGRES_PORT=5433
