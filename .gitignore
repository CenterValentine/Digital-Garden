# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── testing ─────────────────────────────────────────────────────────────────
/coverage

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/playwright/.auth/

# ── next.js + production builds ─────────────────────────────────────────────
/.next/
/out/
/build

# Vercel
.vercel

# TypeScript build artifacts
*.tsbuildinfo
next-env.d.ts

# ── Prisma generated client ─────────────────────────────────────────────────
# Actual path is lib/database/generated/prisma (per prisma schema generator).
/lib/database/generated

# ── env files (opt-in for committing if needed) ─────────────────────────────
.env*

# ── local-only AI/developer artifacts ───────────────────────────────────────
# Local agent / AI assistant working files. The `.claude/worktrees/` path
# holds checkouts of this same repo for parallel agent sessions; including
# it would create embedded-repo problems.
.claude/worktrees/
.memsearch/

# Generic local-only files
.local.*

# Top-level git worktrees (local-only dev artifact)
.worktrees/

# ── editor / OS noise ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*.pem

# Office lock/temp files
~$*

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── macOS Finder duplicate files (prevent " 2", " 3" suffix copies) ─────────
**/* [0-9].js
**/* [0-9].ts
**/* [0-9].mjs
**/* [0-9].json
**/* [0-9].md
**/* [0-9].txt

# ── archived apps (not in build) ────────────────────────────────────────────
archive/
